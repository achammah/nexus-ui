{
  "name": "@nexus/ui",
  "version": "0.2.0",
  "private": true,
  "description": "Nexus UI — org component library: vendored shadcn/ui (new-york-v4, MIT) bridged to the Nexus token canvas + the record-core (table, kanban, record page). Distributed as SOURCE: consumers vendor src/ and own every pixel.",
  "type": "module",
  "scripts": {
    "vendor:shadcn": "node scripts/vendor-shadcn.mjs"
  },
  "exports": {
    ".": "./src/index.ts",
    "./tokens.css": "./src/tokens/tokens.css",
    "./shadcn.css": "./src/styles/shadcn.css"
  },
  "peerDependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@tanstack/react-table": "^8.20.0",
    "@tanstack/react-virtual": "^3.10.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.0",
    "lucide-react": "^0.427.0",
    "radix-ui": "^1.1.0",
    "tailwind-merge": "^2.5.0",
    "tw-animate-css": "^1.2.0"
  },
  "devDependencies": {
    "tailwindcss": "^4.0.0"
  }
}
